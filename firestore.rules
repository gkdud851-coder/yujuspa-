rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (admin, customer)
    //
    // Collection: reservations
    // Document ID: reservationId
    // Fields:
    //   - userId: string
    //   - customerName: string (required)
    //   - customerPhone: string
    //   - date: string (YYYY-MM-DD)
    //   - time: string (HH:mm)
    //   - adultsMale: number
    //   - adultsFemale: number
    //   - kidsMale: number
    //   - kidsFemale: number
    //   - courseId: string (vip-90, vip-120)
    //   - status: string (pending, confirmed, completed, cancelled)
    //   - totalPrice: number
    //   - assignedRoomId: string
    //   - vehicleInfo: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "gkdud851@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role']) &&
             data.email is string &&
             data.role in ['admin', 'customer'];
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['customerName', 'date', 'time', 'courseId', 'status']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.date is string && data.date.matches("^\\d{4}-\\d{2}-\\d{2}$") &&
             data.time is string && data.time.matches("^\\d{2}:\\d{2}$") &&
             data.courseId in ['vip-90', 'vip-120'] &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'customer' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin());
    }

    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidReservation(request.resource.data) && 
                    (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidReservation(request.resource.data) && 
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
